# === Kesh — Configuration ===
# Copier ce fichier vers .env et adapter les valeurs

# --- Base de données ---
DATABASE_URL=mysql://kesh:kesh_dev@localhost:3306/kesh

# --- Application ---
KESH_PORT=3000

# --- Compte admin initial (FR3) ---
KESH_ADMIN_USERNAME=admin
KESH_ADMIN_PASSWORD=changeme

# --- Docker ---
COMPOSE_PROJECT_NAME=kesh

# --- Variables supplémentaires ajoutées dans les stories suivantes ---
# Auth (Story 1.5-1.6): KESH_JWT_SECRET, KESH_JWT_EXPIRY_MINUTES, KESH_REFRESH_TOKEN_EXPIRY_DAYS
# i18n (Story 2.1): KESH_LANG
# Logging (Story 8.4): RUST_LOG

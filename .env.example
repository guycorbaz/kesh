# === Kesh — Configuration ===
# Copier ce fichier vers .env et adapter les valeurs

# --- Base de données ---
DATABASE_URL=mysql://kesh:kesh_dev@127.0.0.1:3306/kesh
MARIADB_ROOT_PASSWORD=kesh_dev_root
MARIADB_DATABASE=kesh
MARIADB_USER=kesh
MARIADB_PASSWORD=kesh_dev

# --- Application ---
KESH_PORT=3000
KESH_HOST=0.0.0.0

# --- Compte admin initial (FR3) ---
KESH_ADMIN_USERNAME=admin
KESH_ADMIN_PASSWORD=changeme

# --- Authentification (Story 1.5) ---
# OBLIGATOIRE en production. Minimum 32 bytes. Générer via : openssl rand -hex 32
KESH_JWT_SECRET=change-me-32-bytes-minimum-secret-generate-with-openssl-rand-hex-32
# Durée de vie de l'access token JWT en minutes (défaut 15, borne 1-1440)
KESH_JWT_EXPIRY_MINUTES=15
# Lifetime absolu du refresh token en jours (défaut 30, borne 1-365)
# Note : la sliding expiration « 15 min d'inactivité » sera ajoutée en story 1.6
KESH_REFRESH_TOKEN_MAX_LIFETIME_DAYS=30

# --- Docker ---
COMPOSE_PROJECT_NAME=kesh

# --- Logging ---
RUST_LOG=info

# --- Variables ajoutées dans les stories suivantes ---
# i18n (Story 2.1): KESH_LANG

# === Kesh — Configuration ===
# Copier ce fichier vers .env et adapter les valeurs

# --- Base de données ---
DATABASE_URL=mysql://kesh:kesh_dev@127.0.0.1:3306/kesh
MARIADB_ROOT_PASSWORD=kesh_dev_root
MARIADB_DATABASE=kesh
MARIADB_USER=kesh
MARIADB_PASSWORD=kesh_dev

# --- Application ---
KESH_PORT=3000
# Défaut applicatif : 127.0.0.1 (sécurité par défaut, Story 6.4 T7.6).
# Set to 0.0.0.0 ONLY for prod docker-compose where reverse proxy fronts the container.
# ATTENTION : KESH_TEST_MODE=true exige un bind loopback (127.0.0.1 / ::1 / localhost).
KESH_HOST=127.0.0.1

# --- Compte admin initial (FR3) ---
KESH_ADMIN_USERNAME=admin
KESH_ADMIN_PASSWORD=changeme

# --- Authentification (Story 1.5) ---
# OBLIGATOIRE en production. Minimum 32 bytes. Générer via : openssl rand -hex 32
KESH_JWT_SECRET=change-me-32-bytes-minimum-secret-generate-with-openssl-rand-hex-32
# Durée de vie de l'access token JWT en minutes (défaut 15, borne 1-1440)
KESH_JWT_EXPIRY_MINUTES=15
# Lifetime absolu du refresh token en jours (défaut 30, borne 1-365)
KESH_REFRESH_TOKEN_MAX_LIFETIME_DAYS=30

# --- Session & Rate Limiting (Story 1.6) ---
# Sliding expiration : durée d'inactivité avant expiration du refresh token (défaut 15, borne 1-1440)
KESH_REFRESH_INACTIVITY_MINUTES=15
# Rate limiting sur /api/v1/auth/login : fenêtre de comptage en minutes (défaut 15, borne 1-1440)
KESH_RATE_LIMIT_WINDOW_MINUTES=15
# Rate limiting : nombre max de tentatives échouées par IP dans la fenêtre (défaut 5, borne 1-100)
KESH_RATE_LIMIT_MAX_ATTEMPTS=5
# Rate limiting : durée de blocage en minutes après dépassement du seuil (défaut 30, borne 1-1440)
KESH_RATE_LIMIT_BLOCK_MINUTES=30

# --- Docker ---
COMPOSE_PROJECT_NAME=kesh

# --- Logging ---
RUST_LOG=info

# --- Variables ajoutées dans les stories suivantes ---
# i18n (Story 2.1): KESH_LANG
